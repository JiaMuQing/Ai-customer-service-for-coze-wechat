# =============================================================================
# 请复制本文件为 .env 并填写下面所有「需要你填写」的项；未标注的可保持默认。
# =============================================================================

# ------------------------------ 服务与端口 -----------------------------------
PORT=3000
# 需要你填写：若部署到公网，填实际域名，用于企业微信回调校验等（如 https://your-domain.com）
BASE_URL=https://your-domain.com

# ------------------------------ 固定登录账号（本期无权限系统）------------------
# 需要你填写：管理后台登录用户名（固定写死，不落库）
ADMIN_USERNAME=xxx
# 需要你填写：管理后台登录密码（固定写死，不落库）
ADMIN_PASSWORD=xxx
# 需要你填写：JWT 密钥，用于签发登录 token（建议随机长字符串）
JWT_SECRET=xxx

# ------------------------------ MySQL ---------------------------------------
# 需要你填写：数据库主机
DB_HOST=xxx
# 需要你填写：数据库端口
DB_PORT=xxxx
# 需要你填写：数据库名（需先手动创建）
DB_DATABASE=xxx
# 需要你填写：数据库用户名
DB_USERNAME=xxx
# 需要你填写：数据库密码
DB_PASSWORD=xxx

# ------------------------------ Redis ---------------------------------------
# 需要你填写：Redis 主机
REDIS_HOST=xxx
# 需要你填写：Redis 端口
REDIS_PORT=xxxx
# 可选：Redis 密码，无密码留空
REDIS_PASSWORD=
# 可选：Redis DB 编号，默认 0
REDIS_DB=0

# ------------------------------ 扣子 Coze -----------------------------------
# 需要你填写：扣子开放平台 PAT（个人访问令牌），需包含 chat、知识库等权限
# 获取路径：扣子开放平台 -> 开发者设置 -> 个人访问令牌
COZE_API_BASE=https://api.coze.cn
COZE_PAT=xxxx
# 需要你填写：扣子 Bot ID（从 Bot 开发页 URL 或发布设置中获取）
COZE_BOT_ID=xxx

# ------------------------------ 企业微信 ------------------------------------
# 需要你填写：企业 ID。获取路径：企业微信管理后台 -> 我的企业 -> 企业信息
WECOM_CORP_ID=xxx
# 需要你填写：自建应用 Secret。获取路径：应用管理 -> 自建 -> 某应用 -> Secret
WECOM_CORP_SECRET=xxx
# 需要你填写：自建应用 AgentId。获取路径：应用管理 -> 自建 -> 某应用 -> AgentId
WECOM_AGENT_ID=xxx
# 需要你填写：智能机器人接收消息回调的 Token（与企微后台配置一致）
# 获取路径：应用 -> 智能机器人 -> 接收消息 -> 设置 Token
WECOM_BOT_TOKEN=xxx
# 需要你填写：智能机器人接收消息回调的 EncodingAESKey（与企微后台配置一致）
# 获取路径：应用 -> 智能机器人 -> 接收消息 -> 设置 EncodingAESKey
WECOM_BOT_AES_KEY=xxx
