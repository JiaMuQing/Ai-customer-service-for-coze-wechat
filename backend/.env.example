# =============================================================================
# 请复制本文件为 .env 并填写下面所有「需要你填写」的项；未标注的可保持默认。
# =============================================================================

# ------------------------------ 服务与端口 -----------------------------------
PORT=3000
# 可选：部署后的公网域名（如 https://your-domain.com）
BASE_URL=https://your-domain.com

# ------------------------------ 固定登录账号（本期无权限系统）------------------
# 需要你填写：管理后台登录用户名（固定写死，不落库）
ADMIN_USERNAME=xxx
# 需要你填写：管理后台登录密码（固定写死，不落库）
ADMIN_PASSWORD=xxx
# 需要你填写：JWT 密钥，用于签发登录 token（建议随机长字符串）
JWT_SECRET=xxx

# ------------------------------ MySQL ---------------------------------------
# 需要你填写：数据库主机
DB_HOST=xxx
# 需要你填写：数据库端口
DB_PORT=xxxx
# 需要你填写：数据库名（需先手动创建）
DB_DATABASE=xxx
# 需要你填写：数据库用户名
DB_USERNAME=xxx
# 需要你填写：数据库密码
DB_PASSWORD=xxx

# ------------------------------ 扣子 Coze -----------------------------------
# 需要你填写：扣子开放平台 PAT（个人访问令牌），需包含 chat、知识库等权限
# 获取路径：扣子开放平台 -> 开发者设置 -> 个人访问令牌
COZE_API_BASE=https://api.coze.cn
COZE_PAT=xxxx
# 需要你填写：扣子 Bot ID（从 Bot 开发页 URL 或发布设置中获取）
COZE_BOT_ID=xxx
# 可选：本地调试时设为 1，终端会打印 /v3/chat 请求体与扣子返回的完整 JSON（勿在生产开启）
# COZE_DEBUG=1
# 可选：非流式对话轮询间隔/超时（毫秒）
# COZE_POLL_INTERVAL_MS=500
# COZE_POLL_TIMEOUT_MS=120000
